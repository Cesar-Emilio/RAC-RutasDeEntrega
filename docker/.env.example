# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-segura
SECRET_KEY=cambia-esto-por-una-clave-segura
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_NAME=rac_db
DB_USER=rac_user
DB_PASSWORD=cambia-password-db
DB_ROOT_PASSWORD=cambia-root-password
DB_PORT=3306

# ── CORS / URLs ───────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=cambia-esto-por-un-jwt-secreto
JWT_ALGORITHM=HS256
JWT_EXP_DELTA_SECONDS=3600
LOGIN_THROTTLE_RATE=3/min

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback/

# ── Gmail API ─────────────────────────────────────────────────────────────────
GOOGLE_EMAIL_USER=correo@utez.edu.mx
GOOGLE_EMAIL_APP_PASSWORD=tu-app-password
GOOGLE_CREDENTIALS_PATH=/app/google-credentials.json

# ── Frontend (Next.js build args) ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ORS_API_KEY=tu-ors-api-key

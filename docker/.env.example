# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-segura
SECRET_KEY=cambia-esto-por-una-clave-segura
DEBUG=False
ALLOWED_HOSTS=nombre-del-dominio,www.nombre-del-dominio
# Generar DJANGO_SECRET_KEY:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#
# Generar JWT_SECRET_KEY:
# python -c "import secrets; print(secrets.token_urlsafe(64))"

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_NAME=rac_db
DB_USER=rac_user
DB_PASSWORD=cambia-password-db
DB_ROOT_PASSWORD=cambia-root-password
DB_PORT=3306

# ── CORS / URLs ───────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://nombre-del-dominio,https://www.nombre-del-dominio
FRONTEND_BASE_URL=https://nombre-del-dominio
FRONTEND_URL=https://nombre-del-dominio

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=cambia-esto-por-un-jwt-secreto
JWT_ALGORITHM=HS256
JWT_EXP_DELTA_SECONDS=3600
LOGIN_THROTTLE_RATE=3/min

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret
GOOGLE_REDIRECT_URI=https://nombre-del-dominio/api/auth/google/callback/

# ── Gmail API ─────────────────────────────────────────────────────────────────
GOOGLE_EMAIL_USER=correo@utez.edu.mx
GOOGLE_EMAIL_APP_PASSWORD=tu-app-password
GOOGLE_CREDENTIALS_PATH=/app/google-credentials.json

# ── Frontend (Next.js build args) ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://nombre-del-dominio
NEXT_PUBLIC_ORS_API_KEY=tu-ors-api-key
